# Application
APP_VERSION=1.0.0
ENVIRONMENT=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
SERVER_TIMEOUT=30000
SERVER_BODY_LIMIT=10mb

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=myapp
DB_USER=postgres
# DB_PASSWORD is loaded from secret file
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=10000
DB_MIGRATIONS_AUTO=true

# Redis
REDIS_MODE=standalone
REDIS_HOSTS=redis:6379
# REDIS_PASSWORD is loaded from secret file if needed
REDIS_DB=0
REDIS_KEY_PREFIX=myapp:
REDIS_TIMEOUT=5000
REDIS_RETRY_ATTEMPTS=3

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_FILE_PATH=/var/log/app/app.log
LOG_FILE_MAX_SIZE=100
LOG_FILE_MAX_COUNT=5

# Monitoring
MONITORING_ENABLED=true
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8080
HEALTH_CHECK_PATH=/health

# Tracing (development)
TRACING_ENABLED=true
TRACING_SERVICE_NAME=myapp-dev
TRACING_ENDPOINT=http://jaeger:14268/api/traces

# API
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=20
CORS_ENABLED=true
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_CREDENTIALS=true

# JWT
JWT_ENABLED=true
# JWT_SECRET is loaded from secret file
JWT_EXPIRY=24h
JWT_REFRESH_ENABLED=true

# External API Keys (loaded from secrets in production)
# STRIPE_API_KEY, SENDGRID_API_KEY, etc.

# External Services
PAYMENT_SERVICE_URL=http://payment-service:8000
PAYMENT_SERVICE_TIMEOUT=10000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
NOTIFICATION_SERVICE_TIMEOUT=5000

# Feature Flags
FEATURE_NEW_UI=true
FEATURE_BETA_API=true
FEATURE_EXP_CACHE=true

# Cache
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_ENTRIES=1000

# Debug
DEBUG_CONFIG=false
VALIDATE_CONFIG=true
